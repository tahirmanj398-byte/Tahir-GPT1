# TAHIR GPT - ENVIRONMENT CONFIGURATION
# --------------------------------------------------

# 1. GEMINI AI API KEY (MANDATORY)
# Get your free or paid key from: https://aistudio.google.com/app/apikey
# This key powers the Chat, Image Generation, and Website Generation features.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 2. VERCEL DEPLOYMENT TOKEN (OPTIONAL)
# Required only if you want to use the "Deploy to Vercel" feature in the Website Generator.
# Get your token from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# 3. APP CONFIGURATION (AUTOMATIC)
# These are usually handled by the hosting platform (Vercel/AI Studio).
NODE_ENV=production
PORT=3000
